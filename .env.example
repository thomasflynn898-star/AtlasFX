# AtlasFX — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | production
# Controls log verbosity, database selection, safety checks

# ── Database ──────────────────────────────────────────────────
DB_PATH=data/atlasfx.db
# Relative to project root. For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/atlasfx

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# ── OANDA Broker (Phase 4) ────────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
# Options: practice | live
# WARNING: Set to 'live' only when deliberately trading with real money.
# practice = https://api-fxpractice.oanda.com
# live     = https://api-fxtrade.oanda.com

# ── Notifications — Pushover (optional) ──────────────────────
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
# Get from: https://pushover.net

# ── Notifications — Telegram (optional) ──────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notifications — Email (optional) ─────────────────────────
EMAIL_ENABLED=false
EMAIL_FROM=
EMAIL_TO=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_PASSWORD=

# ── Risk Parameters (overridable in development only) ─────────
# WARNING: In production these are enforced by risk/engine.py
# regardless of what is set here.
RISK_PER_TRADE_PCT=0.5
MAX_DAILY_DRAWDOWN_PCT=2.0
MAX_WEEKLY_DRAWDOWN_PCT=5.0
MAX_CONCURRENT_EXPOSURE_PCT=2.0

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8420
DASHBOARD_SECRET_KEY=change-this-to-a-random-string

# ── Data ──────────────────────────────────────────────────────
DATA_HISTORICAL_PATH=data/historical
DATA_LIVE_PATH=data/live
DATA_NEWS_PATH=data/news
